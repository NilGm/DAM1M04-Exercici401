<div class="card">
    <h2>Fitxa del Client: {{customer.name}}</h2>
    <p><b>Email:</b> {{customer.email}} | <b>Telèfon:</b> {{customer.phone}}</p>
    <div style="display: flex; gap: 20px; background: #eee; padding: 10px; margin: 15px 0; color: #000; border-radius: 4px;">
        <p><b>Total gastat:</b> {{stats.total_gastat}}€</p>
        <p><b>Ticket mitjà:</b> {{stats.ticket_mig}}€</p>
    </div>

    <h3>Historial d'últimes 10 compres</h3>
    <table>
        <thead>
            <tr><th>ID Venda</th><th>Data</th><th>Mètode Pagament</th><th>Total</th></tr>
        </thead>
        <tbody>
            {{#each sales}}
            <tr><td>#{{this.id}}</td><td>{{formatDate this.sale_date}}</td><td>{{this.payment_method}}</td><td><b>{{this.total}}€</b></td></tr>
            {{else}}
            <tr><td colspan="4">Aquest client no té compres registrades.</td></tr>
            {{/each}}
        </tbody>
    </table>
    <a href="/clients" class="btn-action" style="background: #aaa; margin-top: 15px;">Tornar al llistat</a>
</div>