<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2>Editar Client #{{customer.id}}</h2>
    <form action="/clients/Update" method="POST" id="form-client" novalidate>
        <input type="hidden" name="taula" value="clients">
        <input type="hidden" name="id" value="{{customer.id}}">
        <div style="margin-bottom: 10px;">
            <label>Nom:</label>
            <input type="text" id="name" name="name" value="{{customer.name}}" style="width:100%; padding:6px;">
            <span id="error-name" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Email:</label>
            <input type="email" id="email" name="email" value="{{customer.email}}" style="width:100%; padding:6px;">
            <span id="error-email" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Telèfon:</label>
            <input type="text" id="phone" name="phone" value="{{customer.phone}}" style="width:100%; padding:6px;">
            <span id="error-phone" class="error-msg"></span>
        </div>
        <button type="submit" style="background: blue; color: white; padding: 10px;">Actualitzar</button>
    </form>
    <form action="/clients/Delete" method="POST" style="margin-top: 10px;" onsubmit="return confirm('Segur?');">
        <input type="hidden" name="id" value="{{customer.id}}">
        <button type="submit" style="background: red; color: white; padding: 10px;">Eliminar Client</button>
    </form>
</div>