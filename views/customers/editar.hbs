<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2>Editar Producte #{{product.id}}</h2>
    <hr>
    
    <form action="/productes/Update" method="POST" id="form-producte" novalidate>
        <input type="hidden" name="taula" value="productes">
        <input type="hidden" name="id" value="{{product.id}}">

        <div style="margin-bottom: 15px;">
            <label for="name" style="display: block; margin-bottom: 5px;"><b>Nom del Producte:</b></label>
            <input type="text" id="name" name="name" value="{{product.name}}" style="width: 100%; padding: 8px; box-sizing: border-box;">
            <span id="error-name" class="error-msg"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label for="category" style="display: block; margin-bottom: 5px;"><b>Categoria:</b></label>
            <input type="text" id="category" name="category" value="{{product.category}}" style="width: 100%; padding: 8px; box-sizing: border-box;">
            <span id="error-category" class="error-msg"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label for="price" style="display: block; margin-bottom: 5px;"><b>Preu (€):</b></label>
            <input type="number" id="price" name="price" step="0.01" value="{{product.price}}" style="width: 100%; padding: 8px; box-sizing: border-box;">
            <span id="error-price" class="error-msg"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label for="stock" style="display: block; margin-bottom: 5px;"><b>Estoc Actual:</b></label>
            <input type="number" id="stock" name="stock" step="1" value="{{product.stock}}" style="width: 100%; padding: 8px; box-sizing: border-box;">
            <span id="error-stock" class="error-msg"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px;"><b>Producte Actiu:</b></label>
            <input type="checkbox" id="active" name="active" {{#if product.active}}checked{{/if}} style="transform: scale(1.3); margin-left: 5px;"> Sí
        </div>

        <div style="display: flex; justify-content: space-between; margin-top: 25px;">
            <div style="display: flex; gap: 10px;">
                <button type="submit" style="background-color: #2ecc71;">Actualitzar</button>
                <a href="/productes" class="btn" style="background-color: #95a5a6; text-decoration: none;">Tornar</a>
            </div>
    </form>

            <form action="/productes/Delete" method="POST" onsubmit="return confirm('Segur que vols eliminar aquest producte?');">
                <input type="hidden" name="id" value="{{product.id}}">
                <button type="submit" style="background-color: #e74c3c;">Esborrar Producte</button>
            </form>
        </div>
</div>