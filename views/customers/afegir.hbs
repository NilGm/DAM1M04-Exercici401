<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2>Afegir Client</h2>
    <form action="/clients/create" method="POST" id="form-client" novalidate>
        <input type="hidden" name="taula" value="clients">
        <div style="margin-bottom: 10px;">
            <label>Nom complet:</label>
            <input type="text" id="name" name="name" style="width:100%; padding:6px;">
            <span id="error-name" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Email:</label>
            <input type="email" id="email" name="email" style="width:100%; padding:6px;">
            <span id="error-email" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Telèfon:</label>
            <input type="text" id="phone" name="phone" style="width:100%; padding:6px;">
            <span id="error-phone" class="error-msg"></span>
        </div>
        <button type="submit" style="background: green; color: white; padding: 10px;">Desar Client</button>
    </form>
</div>