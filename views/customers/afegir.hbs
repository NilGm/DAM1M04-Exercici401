<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2>Afegir Nou Producte</h2>
    <hr>
    
    <form action="/productes/create" method="POST" id="form-producte" novalidate>
        <input type="hidden" name="taula" value="productes">

        <div style="margin-bottom: 15px;">
            <label for="name" style="display: block; margin-bottom: 5px;"><b>Nom del Producte (Obligatori):</b></label>
            <input type="text" id="name" name="name" style="width: 100%; padding: 8px; box-sizing: border-box;">
            <span id="error-name" class="error-msg"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label for="category" style="display: block; margin-bottom: 5px;"><b>Categoria (Obligatori):</b></label>
            <input type="text" id="category" name="category" style="width: 100%; padding: 8px; box-sizing: border-box;">
            <span id="error-category" class="error-msg"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label for="price" style="display: block; margin-bottom: 5px;"><b>Preu (€):</b></label>
            <input type="number" id="price" name="price" step="0.01" style="width: 100%; padding: 8px; box-sizing: border-box;">
            <span id="error-price" class="error-msg"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label for="stock" style="display: block; margin-bottom: 5px;"><b>Estoc Inicial:</b></label>
            <input type="number" id="stock" name="stock" step="1" style="width: 100%; padding: 8px; box-sizing: border-box;">
            <span id="error-stock" class="error-msg"></span>
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px;"><b>Producte Actiu:</b></label>
            <input type="checkbox" id="active" name="active" checked style="transform: scale(1.3); margin-left: 5px;"> Sí
        </div>

        <div style="display: flex; gap: 10px; margin-top: 20px;">
            <button type="submit" style="background-color: #2ecc71;">Desar Producte</button>
            <a href="/productes" class="btn" style="background-color: #e74c3c; text-decoration: none;">Cancel·lar</a>
        </div>
    </form>
</div>