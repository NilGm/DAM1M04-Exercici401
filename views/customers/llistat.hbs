<div class="card">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <h2>Gestió de Clients</h2>
        <a href="/clients/clientAfegir" class="btn-action" style="background-color: green;">+ Afegir Client</a>
    </div>

    <div style="margin: 15px 0;">
        <form action="/clients" method="GET" style="display: flex; gap: 15px; align-items: center;">
            <input type="text" name="cerca" value="{{cerca}}" placeholder="Cerca per nom o email...">
            <label><input type="checkbox" name="vip" value="true" {{#if vip}}checked{{/if}} onchange="this.form.submit()"> ⭐ Clients VIP (+5 compres)</label>
            <button type="submit">Buscar</button>
        </form>
    </div>

    <table>
        <thead>
            <tr><th>Nom</th><th>Email</th><th>Telèfon</th><th>Compres</th><th>Total Gastat</th><th>Accions</th></tr>
        </thead>
        <tbody>
            {{#each customers}}
            <tr>
                <td>{{this.name}}</td>
                <td>{{this.email}}</td>
                <td>{{this.phone}}</td>
                <td>{{this.compres}}</td>
                <td><b>{{this.total_gastat}}€</b></td>
                <td>
                    <a href="/clients/clientFitxa?id={{this.id}}" class="btn-action" style="background: DodgerBlue;">Fitxa</a>
                    <a href="/clients/clientEditar?id={{this.id}}" class="btn-action" style="background: Gold; color: black;">Editar</a>
                </td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div style="display: flex; justify-content: space-between; margin-top: 15px;">
        {{#if (eq pagina 0)}}<button disabled>Anterior</button>
        {{else}}<a href="/clients?pagina={{numSubtract pagina 1}}&cerca={{cerca}}&vip={{vip}}" class="btn-action" style="background: var(--btn);">Anterior</a>{{/if}}
        <span>Pàgina: {{pagina}}</span>
        <a href="/clients?pagina={{numAdd pagina 1}}&cerca={{cerca}}&vip={{vip}}" class="btn-action" style="background: var(--btn);">Següent</a>
    </div>
</div>