<div class="card">
    <h2>Gestió de Productes</h2>
    
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
        <form action="/productes" method="GET" style="display: flex; gap: 10px;">
            <input type="text" name="cerca" value="{{cerca}}" placeholder="Cerca per nom o categoria...">
            <button type="submit">Buscar</button>
            {{#if cerca}}
                <a href="/productes" class="btn" style="background-color: #95a5a6; text-decoration: none;">Netejar</a>
            {{/if}}
        </form>

        <button id="toggle-colors" type="button">Activar/Desactivar Colors Estoc</button>
    </div>

    <table class="taula-estoc">
        <thead>
            <tr>
                <th>Nom</th>
                <th>Categoria</th>
                <th>Preu</th>
                <th>Estoc</th>
                <th>Actiu</th>
                <th>Accions</th>
            </tr>
        </thead>
        <tbody>
            {{#each products}}
            <tr>
                <td>{{this.name}}</td>
                <td>{{this.category}}</td>
                <td>{{this.price}}€</td>
                <td class="{{calculateStockClass this.stock}}"><b>{{this.stock}}</b></td>
                <td>
                    {{#if this.active}}
                        <span style="color: green;">Sí</span>
                    {{else}}
                        <span style="color: red;">No</span>
                    {{/if}}
                </td>
                <td>
                    <a href="/productes/producteEditar?id={{this.id}}" class="btn" style="text-decoration: none; padding: 4px 8px;">Editar</a>
                </td>
            </tr>
            {{else}}
            <tr>
                <td colspan="6" style="text-align: center;">No s'han trobat productes.</td>
            </tr>
            {{/each}}
        </tbody>
    </table>

    <div style="display: flex; justify-content: space-between; margin-top: 15px;">
        {{#if (eq pagina 0)}}
            <button disabled style="background-color: #ccc; cursor: not-allowed;">Anterior</button>
        {{else}}
            <a href="/productes?pagina=0&cerca={{cerca}}" class="btn" style="text-decoration: none;">Anterior</a>
        {{/if}}
        
        <span>Pàgina actual: {{pagina}}</span>

        <a href="/productes?pagina=1&cerca={{cerca}}" class="btn" style="text-decoration: none;">Següent</a>
    </div>
</div>