<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2>Editar Producte #{{product.id}}</h2>
    <form action="/productes/Update" method="POST" id="form-producte" novalidate>
        <input type="hidden" name="taula" value="productes">
        <input type="hidden" name="id" value="{{product.id}}">
        <div style="margin-bottom: 10px;">
            <label>Nom:</label>
            <input type="text" id="name" name="name" value="{{product.name}}" style="width:100%; padding:6px;">
            <span id="error-name" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Categoria:</label>
            <input type="text" id="category" name="category" value="{{product.category}}" style="width:100%; padding:6px;">
            <span id="error-category" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Preu:</label>
            <input type="number" id="price" name="price" step="0.01" value="{{product.price}}" style="width:100%; padding:6px;">
            <span id="error-price" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Estoc:</label>
            <input type="number" id="stock" name="stock" value="{{product.stock}}" style="width:100%; padding:6px;">
            <span id="error-stock" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <input type="checkbox" id="active" name="active" {{#if product.active}}checked{{/if}}> Actiu
        </div>
        <button type="submit" style="background: blue; color: white; padding: 10px;">Actualitzar</button>
    </form>
    <form action="/productes/Delete" method="POST" style="margin-top: 10px;" onsubmit="return confirm('Segur?');">
        <input type="hidden" name="id" value="{{product.id}}">
        <button type="submit" style="background: red; color: white; padding: 10px;">Eliminar Producte</button>
    </form>
</div>