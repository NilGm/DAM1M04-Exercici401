<div class="card" style="max-width: 600px; margin: 0 auto;">
    <h2>Afegir Nou Producte</h2>
    <form action="/productes/create" method="POST" id="form-producte" novalidate>
        <input type="hidden" name="taula" value="productes">
        <div style="margin-bottom: 10px;">
            <label>Nom:</label>
            <input type="text" id="name" name="name" style="width:100%; padding:6px;">
            <span id="error-name" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Categoria:</label>
            <input type="text" id="category" name="category" style="width:100%; padding:6px;">
            <span id="error-category" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Preu (€):</label>
            <input type="number" id="price" name="price" step="0.01" style="width:100%; padding:6px;">
            <span id="error-price" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <label>Estoc Inicial:</label>
            <input type="number" id="stock" name="stock" style="width:100%; padding:6px;">
            <span id="error-stock" class="error-msg"></span>
        </div>
        <div style="margin-bottom: 10px;">
            <input type="checkbox" id="active" name="active" checked> Actiu
        </div>
        <button type="submit" style="background: green; color: white; padding: 10px;">Desar Producte</button>
    </form>
</div>